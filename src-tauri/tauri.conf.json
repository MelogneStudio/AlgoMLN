{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlgoMLN",
  "version": "0.1.0",
  "identifier": "com.algomln.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AlgoMLN",
        "width": 1550,
        "height": 757,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/indices/*"
    ]
  }
}
